# =============================================================================
# Hakken — Discovery Rail · environment template
#
# Every variable below is consumed by src/config/env.ts. Variables marked
# REQUIRED throw at boot if absent; OPTIONAL fall back to safe defaults.
#
# DO NOT commit a populated .env file. .env is gitignored; this template is
# the only env file in the repo.
# =============================================================================

# ----- runtime ---------------------------------------------------------------
NODE_ENV=development
LOG_LEVEL=info
PORT=8080
SERVICE_VERSION=0.1.0-hk1

# ----- database (Supabase eu-west-1; required) -------------------------------
# postgres-js connection string; the rail pins prepare:false at the driver
# layer so this string can include Supabase's pgbouncer pooler URL.
DATABASE_URL=postgres://postgres:<password>@db.<ref>.supabase.co:5432/postgres

# ----- HMAC auth (Hakken rail prefix) ----------------------------------------
# AUTH_RAIL_PREFIX must equal 'Hakken' — the literal value sent in the
# Authorization header: 'Hakken-HMAC-SHA256 ...' per @kmv/platform-shared/hmac.
AUTH_RAIL_PREFIX=Hakken
AUTH_TIMESTAMP_HEADER=x-hakken-timestamp
AUTH_TIMESTAMP_TOLERANCE_SECONDS=300

# ----- idempotency ----------------------------------------------------------
IDEMPOTENCY_TTL_SECONDS=86400

# ----- secrets envelope -----------------------------------------------------
# noop | kms | supabase-vault. v1 starts at noop; flips to supabase-vault
# before Stage 2 pen-test.
SECRETS_ENVELOPE_PROVIDER=noop

# ----- Identiti integration (HK-5) -------------------------------------------
# JWKS for verifying Identiti-issued user JWTs (BearerCustomer).
IDENTITI_JWKS_URL=https://identiti.co.ke/.well-known/jwks.json
IDENTITI_JWT_ISSUER=https://identiti.co.ke
IDENTITI_CONSENT_BASE=https://identiti.co.ke
# Hakken JWT audience (claim 'aud' on incoming user tokens):
HAKKEN_JWT_AUDIENCE=https://hakken.co.ke

# ----- Kipkiren Pay analytical surface (HK-3 / SC-1) -------------------------
# Hakken consumes /analytics/v1/* on KP with Stripe-style HMAC.
KP_API_BASE=https://api.pay.kipkiren.co.ke
KP_ANALYTICS_HMAC_SECRET=
# Hakken's tenant app_id at KP:
KP_TENANT_APP_ID=hakken_internal

# ----- Todoku event emission (HK-7 / TD-14) ----------------------------------
# Hakken POSTs hakken.* events to Todoku /v1/events/ingest.
TODOKU_API_BASE=https://todoku-prod-production.up.railway.app
TODOKU_HMAC_SECRET=
TODOKU_TENANT_APP_ID=hakken_internal

# ----- Kafka (consent.events consumer, HK-4) ---------------------------------
# Comma-separated broker list. Empty → consent cache lives on its 60s TTL only.
KAFKA_BROKERS=
KAFKA_CLIENT_ID=hakken-rail

# ----- Redis cache (HK-3+ ranking + cached_signals) --------------------------
# Empty → in-memory fallback (suitable for HK-1/HK-2 only; required by HK-3).
REDIS_URL=

# ----- regulatory containment (H13-001) --------------------------------------
# When true, the regulatory containment plugin refuses to register and the
# process exits non-zero — used in CI to assert the gate is unconditionally on.
REGULATORY_CONTAINMENT_ENFORCED=true
